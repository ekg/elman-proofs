{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TZu8Ws26uRzf8ue8wFrtP7","type":"tool_result","content":"     1→\"\"\"\n     2→E1H: Multi-Head E1 (Mamba-Gated Elman with independent heads)\n     3→\n     4→Like E1 but with H independent Elman heads, each with its own W_h recurrence.\n     5→Each head maintains a vector state of size n_state.\n     6→\n     7→Architecture:\n     8→    x, z = split(in_proj(x))           # dim -> 2*H*n_state\n     9→    x = silu(x)                        # Pre-activation (like E1/Mamba2)\n    10→    x = reshape(x, [B, T, H, n_state])\n    11→    z = reshape(z, [B, T, H, n_state])\n    12→\n    13→    # Pre-compute W_x for all timesteps (batched GEMM):\n    14→    pre_x = einsum('bthi,hij->bthj', x, W_x)  # [B, T, H, n_state]\n    15→\n    16→    # Sequential recurrence per timestep:\n    17→    for t in range(T):\n    18→        h = tanh(pre_x[:, t] + einsum('bhi,hij->bhj', h_prev, W_h) + b)\n    19→        out[t] = h * silu(z[:, t])\n    20→\n    21→    output = out_proj(reshape(out))     # H*n_state -> dim\n    22→\n    23→Key differences from E1:\n    24→    - E1: single d_inner x d_inner state (one big GEMM per step)\n    25→    - E1H: H independent n_state x n_state states (batched small GEMMs per step)\n    26→\n    27→Key differences from E88:\n    28→    - E88: matrix state (n_state x n_state per head), decay, L2 norm, separate q/k/v\n    29→    - E1H: vector state (n_state per head), no decay, no L2, single in_proj split\n    30→\"\"\"\n    31→\n    32→import torch\n    33→import torch.nn as nn\n    34→import torch.nn.functional as F\n    35→\n    36→# Try to load CUDA kernel\n    37→try:\n    38→    import hasty_pytorch_lib\n    39→    HAS_CUDA = hasattr(hasty_pytorch_lib, 'e1h_forward')\n    40→except ImportError:\n    41→    HAS_CUDA = False\n    42→\n    43→\n    44→class E1HCUDAFunction(torch.autograd.Function):\n    45→    \"\"\"Autograd wrapper for E1H CUDA kernels.\"\"\"\n    46→\n    47→    @staticmethod\n    48→    def forward(ctx, training, pre_x, z, h0, W_h, b_h):\n    49→        \"\"\"\n    50→        Args:\n    51→            pre_x: [B, T, H, N] pre-computed W_x @ silu(x)\n    52→            z: [B, T, H, N] gate values\n    53→            h0: [B, H, N] initial hidden state\n    54→            W_h: [H, N, N] per-head recurrence weight\n    55→            b_h: [H, N] per-head bias\n    56→        Returns:\n    57→            output: [B, T, H, N]\n    58→            h_final: [B, H, N]\n    59→        \"\"\"\n    60→        # CUDA kernel expects [T, B, H, N]\n    61→        pre_x_t = pre_x.permute(1, 0, 2, 3).contiguous()\n    62→        z_t = z.permute(1, 0, 2, 3).contiguous()\n    63→\n    64→        results = hasty_pytorch_lib.e1h_forward(\n    65→            training,\n    66→            pre_x_t,       # [T, B, H, N]\n    67→            z_t,           # [T, B, H, N]\n    68→            h0,            # [B, H, N]\n    69→            W_h,           # [H, N, N]\n    70→            b_h            # [H, N]\n    71→        )\n    72→\n    73→        h_final = results[0]       # [B, H, N]\n    74→        output_t = results[1]      # [T, B, H, N]\n    75→        h_checkpoints = results[2] # [num_cp, B, H, N]\n    76→\n    77→        # Transpose output back to [B, T, H, N]\n    78→        output = output_t.permute(1, 0, 2, 3).contiguous()\n    79→\n    80→        if training:\n    81→            ctx.save_for_backward(pre_x_t, z_t, W_h, b_h, h_checkpoints)\n    82→\n    83→        return output, h_final\n    84→\n    85→    @staticmethod\n    86→    def backward(ctx, d_output, d_h_final):\n    87→        pre_x_t, z_t, W_h, b_h, h_checkpoints = ctx.saved_tensors\n    88→\n    89→        # d_output is [B, T, H, N], transpose to [T, B, H, N]\n    90→        d_output_t = d_output.permute(1, 0, 2, 3).contiguous()\n    91→\n    92→        results = hasty_pytorch_lib.e1h_backward(\n    93→            pre_x_t,           # [T, B, H, N]\n    94→            z_t,               # [T, B, H, N]\n    95→            W_h,               # [H, N, N]\n    96→            b_h,               # [H, N]\n    97→            h_checkpoints,     # [num_cp, B, H, N]\n    98→            d_output_t         # [T, B, H, N]\n    99→        )\n   100→\n   101→        d_pre_x_t = results[0]  # [T, B, H, N]\n   102→        d_z_t = results[1]      # [T, B, H, N]\n   103→        d_W_h_per_b = results[2] # [B, H, N, N] float32\n   104→        d_b_per_b = results[3]   # [B, H, N] float32\n   105→\n   106→        # Transpose gradients back to [B, T, H, N]\n   107→        d_pre_x = d_pre_x_t.permute(1, 0, 2, 3).contiguous()\n   108→        d_z = d_z_t.permute(1, 0, 2, 3).contiguous()\n   109→\n   110→        # Sum d_W_h and d_b across batch dimension\n   111→        d_W_h = d_W_h_per_b.sum(dim=0)  # [H, N, N]\n   112→        d_b = d_b_per_b.sum(dim=0)       # [H, N]\n   113→\n   114→        # Return gradients: training, pre_x, z, h0, W_h, b_h\n   115→        return None, d_pre_x, d_z, None, d_W_h.to(W_h.dtype), d_b.to(b_h.dtype)\n   116→\n   117→\n   118→class E1MultiHead(nn.Module):\n   119→    \"\"\"\n   120→    E1H: Multi-Head E1 layer.\n   121→\n   122→    H independent Elman RNN heads with Mamba2-style split projection gating.\n   123→    Each head has its own W_x, W_h, b parameters operating on n_state-dimensional vectors.\n   124→    \"\"\"\n   125→\n   126→    def __init__(\n   127→        self,\n   128→        dim,\n   129→        n_heads=16,\n   130→        n_state=32,\n   131→        expansion=1.0,  # Ignored when n_heads and n_state are set\n   132→        dropout=0.0,\n   133→        mamba2_init=False,\n   134→        **kwargs  # Accept and ignore extra kwargs from LadderLM\n   135→    ):\n   136→        super().__init__()\n   137→        self.dim = dim\n   138→        self.n_heads = n_heads\n   139→        self.n_state = n_state\n   140→        self.d_inner = n_heads * n_state\n   141→\n   142→        # Mamba2-style: project to 2*d_inner, then split into x (RNN) and z (gate)\n   143→        self.in_proj = nn.Linear(dim, 2 * self.d_inner, bias=False)\n   144→\n   145→        # Per-head parameters: H independent n_state x n_state recurrences\n   146→        # h_i = tanh(x_i @ W_x_i.T + h_prev_i @ W_h_i.T + b_i)\n   147→        self.W_x = nn.Parameter(torch.empty(n_heads, n_state, n_state))\n   148→        self.W_h = nn.Parameter(torch.empty(n_heads, n_state, n_state))\n   149→        self.b = nn.Parameter(torch.zeros(n_heads, n_state))\n   150→\n   151→        # Output projection\n   152→        self.out_proj = nn.Linear(self.d_inner, dim, bias=False)\n   153→\n   154→        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()\n   155→\n   156→        self._init_weights(mamba2_init)\n   157→\n   158→    def _init_weights(self, mamba2_init):\n   159→        if mamba2_init:\n   160→            nn.init.normal_(self.in_proj.weight, std=0.02)\n   161→            nn.init.normal_(self.out_proj.weight, std=0.02)\n   162→            nn.init.normal_(self.W_x, std=0.02)\n   163→            # Orthogonal W_h with spectral radius ~0.999 for each head\n   164→            for h in range(self.n_heads):\n   165→                W_h_fp32 = torch.empty(self.n_state, self.n_state, dtype=torch.float32)\n   166→                nn.init.orthogonal_(W_h_fp32)\n   167→                W_h_fp32.mul_(0.999)\n   168→                with torch.no_grad():\n   169→                    self.W_h.data[h].copy_(W_h_fp32.to(self.W_h.dtype))\n   170→        else:\n   171→            nn.init.xavier_uniform_(self.in_proj.weight)\n   172→            nn.init.xavier_uniform_(self.out_proj.weight)\n   173→            # Per-head xavier\n   174→            for h in range(self.n_heads):\n   175→                nn.init.xavier_uniform_(self.W_x.data[h])\n   176→                nn.init.orthogonal_(self.W_h.data[h])\n   177→                self.W_h.data[h].mul_(0.9)\n   178→\n   179→    def _forward_pytorch(self, x, h0):\n   180→        \"\"\"Pure PyTorch forward (reference / fallback).\"\"\"\n   181→        B, T, D = x.shape\n   182→        H, N = self.n_heads, self.n_state\n   183→\n   184→        # Mamba2-style: project and split\n   185→        xz = self.in_proj(x)  # [B, T, 2*H*N]\n   186→        x_proj, z = xz.chunk(2, dim=-1)  # Each [B, T, H*N]\n   187→\n   188→        # Pre-activation (like E1/Mamba2)\n   189→        x_proj = F.silu(x_proj)\n   190→\n   191→        # Reshape to per-head\n   192→        x_proj = x_proj.view(B, T, H, N)  # [B, T, H, N]\n   193→        z = z.view(B, T, H, N)  # [B, T, H, N]\n   194→\n   195→        # Pre-compute W_x @ x for all timesteps (batched GEMM over heads and time)\n   196→        pre_x = torch.einsum('bthi,hij->bthj', x_proj, self.W_x)\n   197→\n   198→        # Initial state\n   199→        if h0 is None:\n   200→            h_prev = torch.zeros(B, H, N, device=x.device, dtype=x.dtype)\n   201→        else:\n   202→            h_prev = h0\n   203→\n   204→        # Sequential recurrence\n   205→        outputs = []\n   206→        for t in range(T):\n   207→            wh = torch.einsum('bhi,hij->bhj', h_prev, self.W_h)\n   208→            h_new = torch.tanh(pre_x[:, t] + wh + self.b)\n   209→            out_t = h_new * F.silu(z[:, t])\n   210→            outputs.append(out_t)\n   211→            h_prev = h_new\n   212→\n   213→        output = torch.stack(outputs, dim=1)  # [B, T, H, N]\n   214→        output = output.reshape(B, T, self.d_inner)\n   215→        output = self.dropout(output)\n   216→        output = self.out_proj(output)\n   217→\n   218→        return output, h_prev\n   219→\n   220→    def forward(self, x, h0=None, **kwargs):\n   221→        \"\"\"\n   222→        Args:\n   223→            x: [B, T, dim] input sequence\n   224→            h0: [B, H, n_state] initial hidden state, or None\n   225→\n   226→        Returns:\n   227→            output: [B, T, dim] output sequence\n   228→            h_final: [B, H, n_state] final hidden state\n   229→        \"\"\"\n   230→        B, T, D = x.shape\n   231→        H, N = self.n_heads, self.n_state\n   232→\n   233→        use_cuda = HAS_CUDA and x.is_cuda and x.dtype == torch.bfloat16\n   234→\n   235→        if not use_cuda:\n   236→            return self._forward_pytorch(x, h0)\n   237→\n   238→        # CUDA path: compute projections in Python, recurrence in CUDA\n   239→        xz = self.in_proj(x)  # [B, T, 2*H*N]\n   240→        x_proj, z = xz.chunk(2, dim=-1)\n   241→\n   242→        x_proj = F.silu(x_proj)\n   243→\n   244→        x_proj = x_proj.view(B, T, H, N)\n   245→        z = z.view(B, T, H, N)\n   246→\n   247→        # Pre-compute W_x @ x\n   248→        pre_x = torch.einsum('bthi,hij->bthj', x_proj, self.W_x)\n   249→\n   250→        if h0 is None:\n   251→            h0 = torch.zeros(B, H, N, device=x.device, dtype=x.dtype)\n   252→\n   253→        # CUDA kernel handles the recurrence\n   254→        output, h_final = E1HCUDAFunction.apply(\n   255→            self.training, pre_x, z, h0, self.W_h, self.b\n   256→        )\n   257→\n   258→        # Reshape and project\n   259→        output = output.reshape(B, T, self.d_inner)\n   260→        output = self.dropout(output)\n   261→        output = self.out_proj(output)\n   262→\n   263→        return output, h_final\n   264→\n   265→    def extra_repr(self):\n   266→        return (f'dim={self.dim}, n_heads={self.n_heads}, n_state={self.n_state}, '\n   267→                f'd_inner={self.d_inner}, LEVEL=E1H_MULTIHEAD')\n   268→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"d6291cb2-b975-4ff1-9999-75725616ecec","uuid":"35718371-ea1c-495d-aafb-9f55b0e29d74","tool_use_result":{"type":"text","file":{"filePath":"/home/erikg/elman/elman/models/e1_multihead.py","content":"\"\"\"\nE1H: Multi-Head E1 (Mamba-Gated Elman with independent heads)\n\nLike E1 but with H independent Elman heads, each with its own W_h recurrence.\nEach head maintains a vector state of size n_state.\n\nArchitecture:\n    x, z = split(in_proj(x))           # dim -> 2*H*n_state\n    x = silu(x)                        # Pre-activation (like E1/Mamba2)\n    x = reshape(x, [B, T, H, n_state])\n    z = reshape(z, [B, T, H, n_state])\n\n    # Pre-compute W_x for all timesteps (batched GEMM):\n    pre_x = einsum('bthi,hij->bthj', x, W_x)  # [B, T, H, n_state]\n\n    # Sequential recurrence per timestep:\n    for t in range(T):\n        h = tanh(pre_x[:, t] + einsum('bhi,hij->bhj', h_prev, W_h) + b)\n        out[t] = h * silu(z[:, t])\n\n    output = out_proj(reshape(out))     # H*n_state -> dim\n\nKey differences from E1:\n    - E1: single d_inner x d_inner state (one big GEMM per step)\n    - E1H: H independent n_state x n_state states (batched small GEMMs per step)\n\nKey differences from E88:\n    - E88: matrix state (n_state x n_state per head), decay, L2 norm, separate q/k/v\n    - E1H: vector state (n_state per head), no decay, no L2, single in_proj split\n\"\"\"\n\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\n\n# Try to load CUDA kernel\ntry:\n    import hasty_pytorch_lib\n    HAS_CUDA = hasattr(hasty_pytorch_lib, 'e1h_forward')\nexcept ImportError:\n    HAS_CUDA = False\n\n\nclass E1HCUDAFunction(torch.autograd.Function):\n    \"\"\"Autograd wrapper for E1H CUDA kernels.\"\"\"\n\n    @staticmethod\n    def forward(ctx, training, pre_x, z, h0, W_h, b_h):\n        \"\"\"\n        Args:\n            pre_x: [B, T, H, N] pre-computed W_x @ silu(x)\n            z: [B, T, H, N] gate values\n            h0: [B, H, N] initial hidden state\n            W_h: [H, N, N] per-head recurrence weight\n            b_h: [H, N] per-head bias\n        Returns:\n            output: [B, T, H, N]\n            h_final: [B, H, N]\n        \"\"\"\n        # CUDA kernel expects [T, B, H, N]\n        pre_x_t = pre_x.permute(1, 0, 2, 3).contiguous()\n        z_t = z.permute(1, 0, 2, 3).contiguous()\n\n        results = hasty_pytorch_lib.e1h_forward(\n            training,\n            pre_x_t,       # [T, B, H, N]\n            z_t,           # [T, B, H, N]\n            h0,            # [B, H, N]\n            W_h,           # [H, N, N]\n            b_h            # [H, N]\n        )\n\n        h_final = results[0]       # [B, H, N]\n        output_t = results[1]      # [T, B, H, N]\n        h_checkpoints = results[2] # [num_cp, B, H, N]\n\n        # Transpose output back to [B, T, H, N]\n        output = output_t.permute(1, 0, 2, 3).contiguous()\n\n        if training:\n            ctx.save_for_backward(pre_x_t, z_t, W_h, b_h, h_checkpoints)\n\n        return output, h_final\n\n    @staticmethod\n    def backward(ctx, d_output, d_h_final):\n        pre_x_t, z_t, W_h, b_h, h_checkpoints = ctx.saved_tensors\n\n        # d_output is [B, T, H, N], transpose to [T, B, H, N]\n        d_output_t = d_output.permute(1, 0, 2, 3).contiguous()\n\n        results = hasty_pytorch_lib.e1h_backward(\n            pre_x_t,           # [T, B, H, N]\n            z_t,               # [T, B, H, N]\n            W_h,               # [H, N, N]\n            b_h,               # [H, N]\n            h_checkpoints,     # [num_cp, B, H, N]\n            d_output_t         # [T, B, H, N]\n        )\n\n        d_pre_x_t = results[0]  # [T, B, H, N]\n        d_z_t = results[1]      # [T, B, H, N]\n        d_W_h_per_b = results[2] # [B, H, N, N] float32\n        d_b_per_b = results[3]   # [B, H, N] float32\n\n        # Transpose gradients back to [B, T, H, N]\n        d_pre_x = d_pre_x_t.permute(1, 0, 2, 3).contiguous()\n        d_z = d_z_t.permute(1, 0, 2, 3).contiguous()\n\n        # Sum d_W_h and d_b across batch dimension\n        d_W_h = d_W_h_per_b.sum(dim=0)  # [H, N, N]\n        d_b = d_b_per_b.sum(dim=0)       # [H, N]\n\n        # Return gradients: training, pre_x, z, h0, W_h, b_h\n        return None, d_pre_x, d_z, None, d_W_h.to(W_h.dtype), d_b.to(b_h.dtype)\n\n\nclass E1MultiHead(nn.Module):\n    \"\"\"\n    E1H: Multi-Head E1 layer.\n\n    H independent Elman RNN heads with Mamba2-style split projection gating.\n    Each head has its own W_x, W_h, b parameters operating on n_state-dimensional vectors.\n    \"\"\"\n\n    def __init__(\n        self,\n        dim,\n        n_heads=16,\n        n_state=32,\n        expansion=1.0,  # Ignored when n_heads and n_state are set\n        dropout=0.0,\n        mamba2_init=False,\n        **kwargs  # Accept and ignore extra kwargs from LadderLM\n    ):\n        super().__init__()\n        self.dim = dim\n        self.n_heads = n_heads\n        self.n_state = n_state\n        self.d_inner = n_heads * n_state\n\n        # Mamba2-style: project to 2*d_inner, then split into x (RNN) and z (gate)\n        self.in_proj = nn.Linear(dim, 2 * self.d_inner, bias=False)\n\n        # Per-head parameters: H independent n_state x n_state recurrences\n        # h_i = tanh(x_i @ W_x_i.T + h_prev_i @ W_h_i.T + b_i)\n        self.W_x = nn.Parameter(torch.empty(n_heads, n_state, n_state))\n        self.W_h = nn.Parameter(torch.empty(n_heads, n_state, n_state))\n        self.b = nn.Parameter(torch.zeros(n_heads, n_state))\n\n        # Output projection\n        self.out_proj = nn.Linear(self.d_inner, dim, bias=False)\n\n        self.dropout = nn.Dropout(dropout) if dropout > 0 else nn.Identity()\n\n        self._init_weights(mamba2_init)\n\n    def _init_weights(self, mamba2_init):\n        if mamba2_init:\n            nn.init.normal_(self.in_proj.weight, std=0.02)\n            nn.init.normal_(self.out_proj.weight, std=0.02)\n            nn.init.normal_(self.W_x, std=0.02)\n            # Orthogonal W_h with spectral radius ~0.999 for each head\n            for h in range(self.n_heads):\n                W_h_fp32 = torch.empty(self.n_state, self.n_state, dtype=torch.float32)\n                nn.init.orthogonal_(W_h_fp32)\n                W_h_fp32.mul_(0.999)\n                with torch.no_grad():\n                    self.W_h.data[h].copy_(W_h_fp32.to(self.W_h.dtype))\n        else:\n            nn.init.xavier_uniform_(self.in_proj.weight)\n            nn.init.xavier_uniform_(self.out_proj.weight)\n            # Per-head xavier\n            for h in range(self.n_heads):\n                nn.init.xavier_uniform_(self.W_x.data[h])\n                nn.init.orthogonal_(self.W_h.data[h])\n                self.W_h.data[h].mul_(0.9)\n\n    def _forward_pytorch(self, x, h0):\n        \"\"\"Pure PyTorch forward (reference / fallback).\"\"\"\n        B, T, D = x.shape\n        H, N = self.n_heads, self.n_state\n\n        # Mamba2-style: project and split\n        xz = self.in_proj(x)  # [B, T, 2*H*N]\n        x_proj, z = xz.chunk(2, dim=-1)  # Each [B, T, H*N]\n\n        # Pre-activation (like E1/Mamba2)\n        x_proj = F.silu(x_proj)\n\n        # Reshape to per-head\n        x_proj = x_proj.view(B, T, H, N)  # [B, T, H, N]\n        z = z.view(B, T, H, N)  # [B, T, H, N]\n\n        # Pre-compute W_x @ x for all timesteps (batched GEMM over heads and time)\n        pre_x = torch.einsum('bthi,hij->bthj', x_proj, self.W_x)\n\n        # Initial state\n        if h0 is None:\n            h_prev = torch.zeros(B, H, N, device=x.device, dtype=x.dtype)\n        else:\n            h_prev = h0\n\n        # Sequential recurrence\n        outputs = []\n        for t in range(T):\n            wh = torch.einsum('bhi,hij->bhj', h_prev, self.W_h)\n            h_new = torch.tanh(pre_x[:, t] + wh + self.b)\n            out_t = h_new * F.silu(z[:, t])\n            outputs.append(out_t)\n            h_prev = h_new\n\n        output = torch.stack(outputs, dim=1)  # [B, T, H, N]\n        output = output.reshape(B, T, self.d_inner)\n        output = self.dropout(output)\n        output = self.out_proj(output)\n\n        return output, h_prev\n\n    def forward(self, x, h0=None, **kwargs):\n        \"\"\"\n        Args:\n            x: [B, T, dim] input sequence\n            h0: [B, H, n_state] initial hidden state, or None\n\n        Returns:\n            output: [B, T, dim] output sequence\n            h_final: [B, H, n_state] final hidden state\n        \"\"\"\n        B, T, D = x.shape\n        H, N = self.n_heads, self.n_state\n\n        use_cuda = HAS_CUDA and x.is_cuda and x.dtype == torch.bfloat16\n\n        if not use_cuda:\n            return self._forward_pytorch(x, h0)\n\n        # CUDA path: compute projections in Python, recurrence in CUDA\n        xz = self.in_proj(x)  # [B, T, 2*H*N]\n        x_proj, z = xz.chunk(2, dim=-1)\n\n        x_proj = F.silu(x_proj)\n\n        x_proj = x_proj.view(B, T, H, N)\n        z = z.view(B, T, H, N)\n\n        # Pre-compute W_x @ x\n        pre_x = torch.einsum('bthi,hij->bthj', x_proj, self.W_x)\n\n        if h0 is None:\n            h0 = torch.zeros(B, H, N, device=x.device, dtype=x.dtype)\n\n        # CUDA kernel handles the recurrence\n        output, h_final = E1HCUDAFunction.apply(\n            self.training, pre_x, z, h0, self.W_h, self.b\n        )\n\n        # Reshape and project\n        output = output.reshape(B, T, self.d_inner)\n        output = self.dropout(output)\n        output = self.out_proj(output)\n\n        return output, h_final\n\n    def extra_repr(self):\n        return (f'dim={self.dim}, n_heads={self.n_heads}, n_state={self.n_state}, '\n                f'd_inner={self.d_inner}, LEVEL=E1H_MULTIHEAD')\n","numLines":268,"startLine":1,"totalLines":268}}}
