e^{2x} > 3 iff x > ln(3)/2 ≈ 0.55\n  1124→    -- Since 1.5 > 0.55, tanh(1.5) > 0.5.\n  1125→    -- tanh(1.5) > 0.5 follows from e^3 > 3.\n  1126→    -- e^1 > 2.718 (from exp_one_gt_d9), so e^3 > 8 > 3.\n  1127→    -- tanh(1.5) = (e^3 - 1)/(e^3 + 1) > (3-1)/(3+1) = 1/2 when e^3 > 3.\n  1128→    have h_tanh_gt_half : tanh (1.5 * 1 + 0) > 0.5 := by\n  1129→      simp only [mul_one, add_zero]\n  1130→      -- tanh(1.5) > 0.5 follows from e^3 > 3\n  1131→      -- tanh(x) = sinh(x)/cosh(x) = (e^x - e^{-x})/(e^x + e^{-x})\n  1132→      -- For x = 1.5: tanh(1.5) = (e^{1.5} - e^{-1.5})/(e^{1.5} + e^{-1.5})\n  1133→      -- Multiplying by e^{1.5}/e^{1.5}: = (e^3 - 1)/(e^3 + 1)\n  1134→      -- This is > 0.5 iff 2(e^3 - 1) > e^3 + 1 iff e^3 > 3\n  1135→      have h_exp1 : exp 1 > 2 := lt_trans (by norm_num : (2 : ℝ) < 2.7182818283) Real.exp_one_gt_d9\n  1136→      have h_exp3_gt_8 : exp 3 > 8 := by\n  1137→        calc exp 3 = exp 1 * exp 1 * exp 1 := by rw [← Real.exp_add, ← Real.exp_add]; norm_num\n  1138→          _ > 2 * 2 * 2 := by nlinarith [exp_pos 1]\n  1139→          _ = 8 := by norm_num\n  1140→      have h_exp15_pos : 0 < exp 1.5 := exp_pos 1.5\n  1141→      have h_exp_neg15_pos : 0 < exp (-1.5) := exp_pos (-1.5)\n  1142→      have h_exp_neg : exp (-1.5) = (exp 1.5)⁻¹ := Real.exp_neg 1.5\n  1143→      have h_exp3_eq : exp 3 = exp 1.5 * exp 1.5 := by rw [← Real.exp_add]; norm_num\n  1144→      have h_inv_pos : 0 < (exp 1.5)⁻¹ := inv_pos.mpr h_exp15_pos\n  1145→      -- Direct computation using the ratio form\n  1146→      rw [Real.tanh_eq_sinh_div_cosh, Real.sinh_eq, Real.cosh_eq]\n  1147→      -- Transform to (e^3 - 1)/(e^3 + 1) form\n  1148→      -- sinh(1.5)/cosh(1.5) = (e^{1.5} - e^{-1.5})/(e^{1.5} + e^{-1.5})\n  1149→      --                     = (e^3 - 1)/(e^3 + 1) after multiplying by e^{1.5}\n  1150→      have h_denom_pos : 0 < exp 3 + 1 := by linarith [exp_pos 3]\n  1151→      have h_num_pos : 0 < exp 3 - 1 := by linarith [exp_pos 3]\n  1152→      have hne1