e proof...","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1982,"cache_read_input_tokens":91659,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1982},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"6cd06645-8a00-4465-88a4-569f84504161","uuid":"2aa951ba-1367-496f-93af-0da45c14452d"}
