rue\n  have h_nonneg : 0 ≤ (1 - |α|^t) / (1 - |α|) := by\n    apply div_nonneg\n    · have hα_nn : 0 ≤ |α| := abs_nonneg _\n      have hα_le : |α| ≤ 1 := le_of_lt hα","numLines":15,"startLine":335,"totalLines":1202}}}
